<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Background color of the splash screen -->
        <item name="windowSplashScreenBackground">#0F0F13</item>
        
        <!-- Animated icon (or static vector) in the center -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_logo_animated</item>
        
        <!-- Post-splash screen theme (the one to switch to after splash) -->
        <item name="postSplashScreenTheme">@android:style/Theme.Material.Light.NoActionBar</item>
    </style>
</resources>
